# Whether to use local LLM (true/false)
# true: Use local LLM (LM Studio, llama.cpp, etc.) (default)
# false: Use OpenAI API (optional)
USE_LOCAL_LLM=true

# Local LLM settings (used when USE_LOCAL_LLM=true)
LOCAL_LLM_BASE_URL=http://127.0.0.1:1235/v1  # Change to your LM Studio port
LOCAL_LLM_MODEL=google/gemma-4-e4b  # Change to your actual model name

# Language for AI responses (ja, en, zh, es, fr)
# Default: ja (Japanese)
LANGUAGE=ja

# OpenAI API key (optional)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
